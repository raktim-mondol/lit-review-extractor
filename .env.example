# Dashscope / Aliyun OpenAI-compatible API
# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit your real keys.

DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-max-2026-01-23

# ── Available model options ────────────────────────────────────────────────────
#
# Text / reasoning models:
#   qwen3.5-plus (vision)
#   qwen3-max-2026-01-23       (default — strong general reasoning)
#   qwen3-coder-next           (coding-focused, latest)
#   qwen3-coder-plus           (coding-focused, balanced)
#   glm-4.7                    (GLM series, fast)
#   glm-5                      (GLM series, advanced)
#   MiniMax-M2.5               (MiniMax series)
#
# Vision-capable models (can process images):
#   qwen3.5-plus               (Qwen vision, plus tier)
#   kimi-k2.5                  (Kimi vision, strong multimodal)
#
# To switch models, change the DASHSCOPE_MODEL value above.
